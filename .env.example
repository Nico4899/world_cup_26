# Copy to .env and fill in. .env is gitignored.

# --- Postgres (matches docker-compose.yml defaults) -----------------------
DATABASE_URL=postgresql+psycopg://wc2026:wc2026_local@localhost:55432/wc2026

# --- External data APIs ---------------------------------------------------
# football-data.org free tier (10 req/min). Without this key the
# football_data_org_refresh + live_events_poll jobs no-op silently.
FOOTBALL_DATA_ORG_KEY=

# TheSportsDB public test key is "123"; only set if you want a personal key.
# THESPORTSDB_API_KEY=

# --- Operator gating ------------------------------------------------------
# Set to require an X-Ops-Token header on /api/v1/_ops/run-job/{name}. Leave
# unset for local dev (the endpoint is open then).
WC2026_OPS_TOKEN=

# --- Phase 10 observability ----------------------------------------------
# Sentry: set the project DSN to enable. Sample rates default to 0.0 (errors
# only). Without SENTRY_DSN the SDK init is a no-op — never blocks startup.
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
# SENTRY_TRACES_SAMPLE_RATE=0.0
# SENTRY_PROFILES_SAMPLE_RATE=0.0
# SENTRY_RELEASE=wc2026-predictor@0.1.0

# --- Phase 10 off-site backup --------------------------------------------
# S3-compatible bucket for daily pg_dump uploads. Defaults to Cloudflare R2
# (set AWS_S3_ENDPOINT_URL to your R2 account URL). Without AWS_S3_BUCKET the
# db_backup job stays local-only.
AWS_S3_BUCKET=
# Cloudflare R2 example:
# AWS_S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# AWS_REGION=auto
AWS_S3_ENDPOINT_URL=
AWS_REGION=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Object-key prefix and retention. The s3 upload helper sweeps older objects
# after each upload so an operator only sees the last N days of dumps.
WC2026_BACKUP_PREFIX=wc2026/backups/
WC2026_BACKUP_RETENTION_DAYS=30

# --- W1.3 calibration post-processing (off by default) -------------------
# Set to 1/true/yes/on to pipe 1X2 outputs through the fitted
# `data/artifacts/platt/latest.npz` calibrator at /api/v1/predictions. Keep
# off until ECE on the multi-tournament holdout improves by >= 0.002.
WC2026_USE_PLATT=

# --- W1.5 local LLM sidecar (Mistral 7B via Ollama) ----------------------
# Unset => LLM features disabled cleanly (no preview card, 503 from
# /api/v1/matches/{id}/llm-preview). Compose ships the sidecar at
# http://ollama:11434.
OLLAMA_BASE_URL=
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M

# --- W1.4 magic-link auth + email previews -------------------------------
# Secret used to sign NextAuth session cookies. Generate with `openssl rand
# -base64 32`. Leave blank to disable auth entirely (the frontend skips the
# Sign-in button + the personalised landing).
AUTH_SECRET=
# Resend email provider (https://resend.com — 3000 free emails / month).
# Without a key the magic-link Email provider can't dispatch links and the
# /api/auth/signin route returns a configuration error.
RESEND_API_KEY=
EMAIL_FROM=WC 2026 Predictions <no-reply@example.com>

# --- Misc -----------------------------------------------------------------
LOG_LEVEL=INFO
